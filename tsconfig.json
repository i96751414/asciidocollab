{
  "compilerOptions": {
    "strict": true,
    "target": "ES2022",
    "module": "node16",
    "moduleResolution": "node16",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "types": ["node"]
  },
  "references": [
    { "path": "packages/domain" },
    { "path": "packages/shared" },
    { "path": "packages/db" },
    { "path": "packages/infrastructure" },
    { "path": "apps/api" }
  ],
  "files": []
}
