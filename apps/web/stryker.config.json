{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "testRunner": "jest",
  "plugins": ["@stryker-mutator/jest-runner"],
  "tsconfigFile": "tsconfig.json",
  "mutate": [
    "src/lib/api/*.ts",
    "src/lib/fs-entry-walker.ts",
    "src/hooks/use-asciidoc-preview.ts",
    "src/hooks/use-auto-save.ts",
    "src/hooks/use-drop-upload.ts",
    "src/hooks/use-editor-preferences.ts",
    "src/hooks/use-file-selection.ts",
    "src/hooks/use-key-binding-settings.ts",
    "src/hooks/use-key-bindings.ts",
    "!src/**/*.test.ts",
    "!src/**/*.test.tsx",
    "!src/**/*.spec.ts",
    "!src/**/*.spec.tsx"
  ],
  "testRunnerNodeArgs": [],
  "jest": {
    "projectType": "custom",
    "configFile": "jest.stryker.config.cjs",
    "enableFindRelatedTests": false
  },
  "timeoutMS": 30000,
  "timeoutFactor": 2,
  "concurrency": 4,
  "coverageAnalysis": "perTest",
  "thresholds": {
    "high": 90,
    "low": 80,
    "break": 70
  },
  "reporters": ["clear-text", "progress", "json"],
  "jsonReporter": {
    "fileName": "reports/mutation/mutation.json"
  }
}
