    "@radix-ui/react-tooltip": "^1.2.8",
    "@replit/codemirror-minimap": "^0.5.2",
    "asciidoctor": "^3.0.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dictionary-de": "^3.0.0",
    "dictionary-en": "^4.0.0",
    "dictionary-es": "^4.0.0",
    "dictionary-fr": "^3.0.0",
    "dictionary-it": "^2.0.0",
