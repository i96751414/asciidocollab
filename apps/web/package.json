{
  "name": "@asciidocollab/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build:worker": "tsc --project src/workers/tsconfig.json",
    "build:asciidoctor-style": "node scripts/build-asciidoctor-style.mjs",
    "build:mathjax-style": "node scripts/build-mathjax-style.mjs",
    "build:mathjax-assets": "node scripts/build-mathjax-assets.mjs",
    "build:asciidoctor-pdf-wasm": "node scripts/build-asciidoctor-pdf-wasm.mjs",
    "build:spellcheck-dictionary": "node scripts/build-spellcheck-dictionary.mjs",
    "predev": "pnpm run build:worker && pnpm run build:asciidoctor-style && pnpm run build:mathjax-style && pnpm run build:mathjax-assets && pnpm run build:asciidoctor-pdf-wasm && pnpm run build:pdfjs-worker && pnpm run build:spellcheck-dictionary && lezer-generator src/lib/codemirror/asciidoc.grammar --output src/lib/codemirror/asciidoc-parser.js",
    "prebuild": "pnpm run build:worker && pnpm run build:asciidoctor-style && pnpm run build:mathjax-style && pnpm run build:mathjax-assets && pnpm run build:asciidoctor-pdf-wasm && pnpm run build:pdfjs-worker && pnpm run build:spellcheck-dictionary && lezer-generator src/lib/codemirror/asciidoc.grammar --output src/lib/codemirror/asciidoc-parser.js",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src/ tests/ e2e/",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:ci": "jest --coverage --coverageReporters=text lcov",
    "check": "tsc --noEmit && eslint src/ tests/ e2e/ && jest --passWithNoTests",
    "e2e": "playwright test",
    "mutate": "stryker run",
    "build:pdfjs-worker": "node scripts/build-pdfjs-worker.mjs"
  },
  "dependencies": {
    "@asciidocollab/asciidoc-core": "workspace:*",
