{
  "name": "@asciidocollab/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build:worker": "tsc --project src/workers/tsconfig.json",
    "predev": "pnpm run build:worker && lezer-generator src/lib/codemirror/asciidoc.grammar --output src/lib/codemirror/asciidoc-parser.js",
    "prebuild": "pnpm run build:worker && lezer-generator src/lib/codemirror/asciidoc.grammar --output src/lib/codemirror/asciidoc-parser.js",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src/ tests/ e2e/",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "check": "tsc --noEmit && eslint src/ tests/ e2e/ && jest --passWithNoTests",
    "e2e": "playwright test"
  },
  "dependencies": {
    "@asciidocollab/shared": "workspace:*",
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/language": "^6.12.3",
    "@codemirror/search": "^6.7.0",
    "@codemirror/state": "^6.6.0",
    "@codemirror/view": "^6.43.0",
    "@lezer/common": "^1.5.2",
    "@lezer/highlight": "^1.2.3",
    "@lezer/lr": "^1.4.10",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@replit/codemirror-minimap": "^0.5.2",
    "asciidoctor": "^3.0.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.17.0",
    "next": "16.2.6",
    "react": "^19.0.6",
    "react-dom": "^19.0.6",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@lezer/generator": "^1.8.0",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.12.4",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.0.6",
    "eslint": "^9.39.0",
    "eslint-config-next": "16.2.6",
    "jest-environment-jsdom": "^30.4.1",
    "shadcn": "^4.8.3",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3"
  }
}
