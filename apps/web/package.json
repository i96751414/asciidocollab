    "dictionary-uk": "^4.0.0",
    "dompurify": "^3.4.11",
    "highlight.js": "^11.11.1",
    "lucide-react": "^1.17.0",
    "mathjax": "^3.2.2",
    "mermaid": "^11.16.0",
    "next": "16.2.6",
    "nspell": "^2.1.5",
    "react": "^19.0.6",
    "react-dom": "^19.0.6",
    "react-resizable-panels": "^2.1.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7",
    "turndown": "^7.2.4",
    "vega": "^6.2.0",
    "vega-lite": "^6.4.3",
    "y-codemirror.next": "^0.3.5",
    "y-protocols": "^1.0.7",
    "yjs": "^13.6.31",
    "zod": "^4.4.3"
  },
  "devDependencies": {
