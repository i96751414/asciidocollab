generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  VIEWER
  EDITOR
  OWNER
}

enum RegistrationMethod {
  SELF_REGISTERED
  INVITED
}

enum FileNodeType {
  FILE
  FOLDER
}

enum GitProvider {
  GITHUB
  GITLAB
  BITBUCKET
}

enum ReviewItemKind {
  COMMENT
  TASK
}

enum ReviewItemStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  WONTFIX
}

enum AnchorState {
  LOCATED
  SECTION
  DETACHED
}

model User {
  id                 String             @id @default(uuid()) @db.Uuid
  email              String             @unique
  displayName        String
  passwordHash       String?
  passwordHistory    String[]
  samlSubject        String?
  mfaSecret          String?
  isAdmin            Boolean            @default(false)
  emailVerified      Boolean            @default(true)
  registrationMethod RegistrationMethod @default(SELF_REGISTERED)
  avatarKey          String?
  appTheme           String             @default("system")
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  memberships             ProjectMember[]
  auditLogs               AuditLog[]
  sessions                Session[]
  passwordResetTokens     PasswordResetToken[]
  emailChangeTokens       EmailChangeToken[]
  emailVerificationTokens EmailVerificationToken[]
  sentInvitations         UserInvitation[]         @relation("InvitedBy")
  keyBindings             UserKeyBinding[]
  editorPreferences       EditorPreferences?
  authoredReviewComments  ReviewComment[]          @relation("ReviewAuthor")
  assignedReviewItems     ReviewComment[]          @relation("ReviewAssignee")
  resolvedReviewItems     ReviewComment[]          @relation("ReviewResolver")
  reviewReactions         ReviewReaction[]
}

model Project {
  id             String    @id @default(uuid()) @db.Uuid
  name           String
  description    String?
  tags           Json?
  language       String?
  archivedAt     DateTime?
  mainFileNodeId String?   @db.Uuid
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  members               ProjectMember[]
  fileNodes             FileNode[]
  mainFile              FileNode?              @relation("ProjectMainFile", fields: [mainFileNodeId], references: [id], onDelete: SetNull)
  gitRepository         GitRepository?
  auditLogs             AuditLog[]
  templates             Template[]             @relation("TemplateSourceProject")
  collaborationSessions CollaborationSession[]
  reviewComments        ReviewComment[]
  renderConfig          ProjectRenderConfig?
}

model ProjectMember {
  projectId String   @db.Uuid
  userId    String   @db.Uuid
  role      Role
  joinedAt  DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([projectId, userId])
}

model FileNode {
  id        String       @id @default(uuid()) @db.Uuid
  projectId String       @db.Uuid
  parentId  String?      @db.Uuid
  name      String
  type      FileNodeType
  path      String
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  project             Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parent              FileNode?  @relation("FileNodeHierarchy", fields: [parentId], references: [id])
  children            FileNode[] @relation("FileNodeHierarchy")
  document            Document?
  asset               Asset?
  mainFileForProjects Project[]  @relation("ProjectMainFile")

  @@unique([projectId, path])
  @@index([projectId])
  @@index([parentId])
}

model Document {
  id         String   @id @default(uuid()) @db.Uuid
  fileNodeId String   @unique @db.Uuid
  contentId  String   @db.Uuid
  yjsStateId String   @db.Uuid
  mimeType   String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  fileNode              FileNode               @relation(fields: [fileNodeId], references: [id], onDelete: Cascade)
  collaborationSessions CollaborationSession[]
  reviewComments        ReviewComment[]
}

model CollaborationSession {
  id         String   @id @default(uuid()) @db.Uuid
  projectId  String   @db.Uuid
  documentId String   @db.Uuid
  createdAt  DateTime @default(now())

  project  Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([projectId, documentId])
  @@index([projectId])
  @@index([documentId])
  @@map("collaboration_sessions")
}

model Asset {
  id         String    @id @db.Uuid
  mimeType   String
  sizeBytes  BigInt
  uploadedAt DateTime  @default(now())
  updatedAt  DateTime?

  fileNode FileNode @relation(fields: [id], references: [id], onDelete: Cascade)

  @@map("assets")
}

model Template {
  id              String   @id @default(uuid()) @db.Uuid
  name            String
  description     String?
  category        String
  sourceProjectId String?  @db.Uuid
  createdAt       DateTime @default(now())

  sourceProject Project? @relation("TemplateSourceProject", fields: [sourceProjectId], references: [id])
}

model GitRepository {
  id            String      @id @default(uuid()) @db.Uuid
  projectId     String      @unique @db.Uuid
  provider      GitProvider
  remoteUrl     String
  credentialRef String
  currentBranch String      @default("main")
  lastSyncAt    DateTime?
  createdAt     DateTime    @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id           String   @id @default(uuid()) @db.Uuid
  userId       String?  @db.Uuid
  projectId    String?  @db.Uuid
  action       String
  resourceType String
  resourceId   String
  timestamp    DateTime @default(now())
  metadata     Json?

  user    User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  project Project? @relation(fields: [projectId], references: [id])

  @@index([projectId])
  @@index([userId])
  @@index([timestamp(sort: Desc), userId, action])
}

// Coalesced, retention-bounded telemetry for account-security attempts that must stay
// account-existence neutral — failed sign-ins and password-reset requests (feature 025).
// Deliberately separate from AuditLog: bounded volume via coalescing, account-existence
// neutral, no FK to User (attempts may target non-existent accounts), purged on a schedule.
// `eventType` discriminates the attempt kind so both share one store, purge, and policy.
model AuthAttemptTelemetry {
  id             String   @id @default(uuid()) @db.Uuid
  eventType      String // 'failed_sign_in' | 'password_reset_request'
  identifier     String
  ipAddress      String // NOT NULL — sentinel "unknown" when origin is unavailable (keeps the coalescing key total)
  userAgent      String?
  windowStart    DateTime
  attemptCount   Int      @default(1)
  firstAttemptAt DateTime
  lastAttemptAt  DateTime

  @@unique([eventType, identifier, ipAddress, windowStart])
  @@index([windowStart])
  @@index([eventType, identifier])
  @@index([eventType, ipAddress, windowStart])
}

model Session {
  id        String   @id @default(uuid())
  userId    String?  @db.Uuid
  sid       String   @unique
  data      Json
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model EmailChangeToken {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @db.Uuid
  tokenHash    String    @unique
  pendingEmail String
  expiresAt    DateTime
  usedAt       DateTime?
  createdAt    DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model UserInvitation {
  id              String    @id @default(uuid()) @db.Uuid
  recipientEmail  String
  invitedByUserId String?   @db.Uuid
  tokenHash       String    @unique
  expiresAt       DateTime
  acceptedAt      DateTime?
  createdAt       DateTime  @default(now())

  invitedBy User? @relation("InvitedBy", fields: [invitedByUserId], references: [id], onDelete: SetNull)

  @@index([recipientEmail])
  @@index([expiresAt])
}

model EmailVerificationToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model SystemSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model UserKeyBinding {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  action    String
  keyCombo  String
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, action])
}

model EditorPreferences {
  id                String   @id @default(uuid()) @db.Uuid
  userId            String   @unique @db.Uuid
  fontSize          Int      @default(14)
  theme             String   @default("default")
  scrollSyncEnabled Boolean  @default(false)
  softWrap          Boolean  @default(true)
  previewStyle      String   @default("asciidocollab")
  spellcheckEnabled Boolean  @default(true)
  minimapEnabled    Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("editor_preferences")
}

model ProjectRenderConfig {
  id        String   @id @default(uuid()) @db.Uuid
  projectId String   @unique @db.Uuid
  config    Json     @default("{}")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@map("project_render_configs")
}

model ReviewComment {
  id                String            @id @default(uuid()) @db.Uuid
  projectId         String            @db.Uuid
  documentId        String            @db.Uuid
  parentId          String?           @db.Uuid
  kind              ReviewItemKind
  body              String
  authorId          String?           @db.Uuid
  status            ReviewItemStatus?
  assigneeId        String?           @db.Uuid
  dueDate           DateTime?         @db.Date
  resolvedAt        DateTime?
  resolvedById      String?           @db.Uuid
  anchorRelPos      Bytes?
  anchorQuotePrefix String?
  anchorQuoteExact  String?
  anchorQuoteSuffix String?
  anchorLineHint    Int?
  anchorSectionId   String?
  anchorState       AnchorState       @default(LOCATED)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  project   Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  document  Document         @relation(fields: [documentId], references: [id], onDelete: Cascade)
  parent    ReviewComment?   @relation("ReviewThread", fields: [parentId], references: [id], onDelete: Cascade)
  replies   ReviewComment[]  @relation("ReviewThread")
  author    User?            @relation("ReviewAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  assignee  User?            @relation("ReviewAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  resolver  User?            @relation("ReviewResolver", fields: [resolvedById], references: [id], onDelete: SetNull)
  reactions ReviewReaction[]

  @@index([projectId])
  @@index([documentId])
  @@index([parentId])
  @@index([assigneeId, status])
  @@index([documentId, resolvedAt])
  @@map("review_comments")
}

model ReviewReaction {
  id              String   @id @default(uuid()) @db.Uuid
  reviewCommentId String   @db.Uuid
  userId          String   @db.Uuid
  emoji           String
  createdAt       DateTime @default(now())

  comment ReviewComment @relation(fields: [reviewCommentId], references: [id], onDelete: Cascade)
  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([reviewCommentId, userId, emoji])
  @@index([reviewCommentId])
  @@map("review_reactions")
}
