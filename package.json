{
  "name": "asciidocollab",
  "private": true,
  "packageManager": "pnpm@11.11.0",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "prepare": "git config core.hooksPath scripts/git-hooks || true",
    "build": "pnpm -r build",
    "lint": "eslint .",
    "test": "pnpm -r test",
    "test:coverage": "pnpm -r test -- --coverage",
    "typecheck": "tsc --noEmit && pnpm --filter @asciidocollab/api typecheck && pnpm --filter @asciidocollab/web typecheck",
    "fresh-onion": "fresh-onion",
    "knip": "knip",
    "semgrep": "semgrep --config p/security-audit --config p/owasp-top-ten --config .semgrep.yml --error --quiet .",
    "audit": "pnpm audit --audit-level=high",
    "e2e:local": "scripts/ci/e2e-local.sh",
    "wasm": "scripts/ci/wasm.sh",
    "gate": "scripts/ci/gate.sh"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@next/eslint-plugin-next": "^16.2.10",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@types/jest": "^30.0.0",
    "@types/pg": "^8.20.0",
    "eslint": "^10.4.0",
    "eslint-plugin-jsdoc": "^63.0.0",
    "eslint-plugin-redos": "^4.5.0",
    "eslint-plugin-security": "^4.0.1",
    "eslint-plugin-unicorn": "^64.0.0",
    "fresh-onion": "1.0.10",
    "globals": "^17.6.0",
    "jest": "^30.4.2",
    "knip": "^6.24.0",
    "pg": "^8.21.0",
    "prisma": "^7.8.0",
    "ts-jest": "^29.4.11",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0"
  }
}
