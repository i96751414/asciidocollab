  "ignore": ["**/dist/**", "**/*.d.ts", "**/coverage/**", "**/.next/**", "specs/**"],
  "ignoreDependencies": [
    "dictionary-.+",
    "tailwindcss-animate",
    "pg",
    "shadcn"
