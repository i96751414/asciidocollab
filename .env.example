# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string.
# Matches the docker-compose.dev.yml defaults for local development.
ASCIIDOCOLLAB_DATABASE_URL=postgresql://asciidocollab:asciidocollab@localhost:5432/asciidocollab

# ─── API server ───────────────────────────────────────────────────────────────
ASCIIDOCOLLAB_API_PORT=4000
ASCIIDOCOLLAB_API_HOST=0.0.0.0
# Must match the URL where users access the frontend.
ASCIIDOCOLLAB_API_FRONTEND_URL=http://localhost:3000
# Comma-separated list of allowed CORS origins.
ASCIIDOCOLLAB_API_CORS_ORIGINS=http://localhost:3000

# ─── Authentication ───────────────────────────────────────────────────────────
# Secrets — generate with: openssl rand -base64 32
# SESSION_SECRET signs the session cookie.
ASCIIDOCOLLAB_AUTH_SESSION_SECRET=CHANGE_ME
# SESSION_ENCRYPTION_KEY encrypts the session payload at rest (AES-256-GCM).
# Must be exactly 32 bytes; base64-encoded output of openssl rand -base64 32 works.
ASCIIDOCOLLAB_AUTH_SESSION_ENCRYPTION_KEY=CHANGE_ME

# Set to false for local HTTP development (must be true in production).
ASCIIDOCOLLAB_AUTH_COOKIE_SECURE=false

# ─── Email ────────────────────────────────────────────────────────────────────
# Provider: smtp | sendgrid | ses
ASCIIDOCOLLAB_AUTH_EMAIL_PROVIDER=smtp
ASCIIDOCOLLAB_AUTH_EMAIL_ENABLED=true
ASCIIDOCOLLAB_AUTH_EMAIL_FROM=noreply@asciidocollab.local

# SMTP — defaults point to Mailpit (docker-compose.dev.yml).
# Open http://localhost:8025 to view captured emails.
ASCIIDOCOLLAB_AUTH_SMTP_HOST=localhost
ASCIIDOCOLLAB_AUTH_SMTP_PORT=1025
# Leave blank for Mailpit (no auth required).
ASCIIDOCOLLAB_AUTH_SMTP_USER=
ASCIIDOCOLLAB_AUTH_SMTP_PASSWORD=

# SendGrid (only needed when EMAIL_PROVIDER=sendgrid)
# ASCIIDOCOLLAB_AUTH_SENDGRID_API_KEY=

# AWS SES (only needed when EMAIL_PROVIDER=ses)
# ASCIIDOCOLLAB_AUTH_SES_REGION=eu-west-1

# ─── Collaboration server ─────────────────────────────────────────────────────
# WebSocket port for apps/collab
ASCIIDOCOLLAB_COLLAB_PORT=4002
# Loopback port apps/api binds its internal auth server to
ASCIIDOCOLLAB_COLLAB_INTERNAL_PORT=4001
# URL apps/collab uses to reach apps/api's internal auth endpoint
ASCIIDOCOLLAB_COLLAB_API_INTERNAL_URL=http://127.0.0.1:4001
# Auth hook timeout (milliseconds)
ASCIIDOCOLLAB_COLLAB_AUTH_TIMEOUT_MS=3000
# Orphaned-room cleanup interval (milliseconds)
ASCIIDOCOLLAB_COLLAB_WATCHDOG_INTERVAL_MS=30000
# Note: ASCIIDOCOLLAB_STORAGE_PATH and ASCIIDOCOLLAB_DATABASE_URL are shared
# with apps/api — no separate entries needed here.

# ─── Preview ─────────────────────────────────────────────────────────────────
# Milliseconds of inactivity before the live AsciiDoc preview auto-refreshes.
# Separate from the 4000 ms auto-save debounce (NEXT_PUBLIC_EDITOR_AUTOSAVE_DEBOUNCE_MS).
NEXT_PUBLIC_PREVIEW_DEBOUNCE_MS=1500
