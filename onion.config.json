{
  "layers": {
    "domain": "./packages/domain/src",
    "shared": "./packages/shared/src",
    "db": "./packages/db/src",
    "infrastructure": "./packages/infrastructure/src"
  },
  "rules": [
    {
      "from": "domain",
      "allowedImports": []
    },
    {
      "from": "shared",
      "allowedImports": ["domain"]
    },
    {
      "from": "db",
      "allowedImports": []
    },
    {
      "from": "infrastructure",
      "allowedImports": ["domain", "shared", "db"]
    }
  ]
}
