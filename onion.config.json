{
  "layers": {
    "asciidoc-core": "./packages/asciidoc-core/src",
    "domain": "./packages/domain/src",
    "shared": "./packages/shared/src",
    "infrastructure": "./packages/infrastructure/src",
    "api": "./apps/api/src",
    "web": "./apps/web/src",
    "collab": "./apps/collab/src"
  },
  "rules": [
    { "from": "asciidoc-core", "allowedImports": [] },
    { "from": "domain", "allowedImports": ["asciidoc-core"] },
    { "from": "shared", "allowedImports": [] },
    { "from": "infrastructure", "allowedImports": ["domain", "shared"] },
    { "from": "api", "allowedImports": ["domain", "infrastructure", "shared"] },
    { "from": "collab", "allowedImports": ["domain", "infrastructure", "shared"] },
    { "from": "web", "allowedImports": ["shared", "asciidoc-core"] }
  ]
}
